# SiteNarrator — Environment Variables
# Copy this file to .env and fill in your values

# ─── AWS ───────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Amazon Bedrock ────────────────────────────────────
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250514

# ─── Amazon Bedrock AgentCore ──────────────────────────
AGENTCORE_MEMORY_ID=
AGENTCORE_GATEWAY_ID=
AGENTCORE_POLICY_ENGINE_ID=

# ─── Box ───────────────────────────────────────────────
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_ENTERPRISE_ID=
BOX_ROOT_FOLDER_ID=

# ─── OpenWeatherMap ────────────────────────────────────
OPENWEATHER_API_KEY=

# ─── Application ───────────────────────────────────────
APP_SECRET_KEY=
APP_ENV=development
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ─── Email Notifications (AWS SES) ────────────────────
SES_SENDER_EMAIL=
SES_REGION=us-east-1

# ─── Observability ─────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=sitenarrator
